    "domcontentloaded",
    "emnapi",
    "eotf",
    "Expectedquality",
    "fflags",
    "formatformat",
    "Gqndesc",
    "Hdrmetadatadegradedesc",
    "KHTML",
    "Mediabasedesc",
    "MJPEG",
    "multimodal",
    "napi",
    "nobuffer",
    "ONNX",
    "openrouter",
    "oxlint",
    "paraformer",
    "pdata",
    "playurl",
    "probesize",
    "probs",
    "ptype",
    "resampler",
    "SENSEVOICE",
    "silero",
    "tybys",
    "uids",
    "Urlinfo",
    "vcodec",
