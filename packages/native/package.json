{
  "name": "@dd-agent/native",
  "version": "0.0.0",
  "description": "Template project for writing node package with napi-rs",
  "keywords": [
    "N-API",
    "NAPI",
    "Rust",
    "napi-rs",
    "node-addon",
    "node-addon-api"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/napi-rs/package-template.git"
  },
  "files": [
    "index.js",
    "*.node"
  ],
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": {
      "default": "./index.js",
      "types": "./index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "devDependencies": {
    "@emnapi/core": "^1.5.0",
    "@emnapi/runtime": "^1.5.0",
    "@napi-rs/cli": "^3.2.0",
    "@tybys/wasm-util": "^0.10.0",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "napi": {
    "binaryName": "dd-agent-native",
    "targets": [
      "x86_64-pc-windows-msvc"
    ]
  },
  "engines": {
    "node": ">= 18.17.0 < 19 || >= 20.3.0 < 21 || >= 21.1.0"
  }
}
