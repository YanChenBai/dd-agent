# Runtime
# Name used by the LLM when the streamer addresses it.
AGENT_NAME=DD
# Stop automatically after N milliseconds. Set 0 to keep running until Ctrl+C.
AGENT_STOP_AFTER_MS=0
# Live room identifier to connect to.
LIVE_ROOM_ID=82568
# Send generated danmaku to the live room with 1. Keep 0 for preview-only mode.
SEND_DANMAKU=0

# Model id exposed by the configured OpenAI-compatible provider.
AI_MODEL=google/gemma-4-26b-a4b-it:free
# Provider API key.
AI_API_KEY=xxxx
# OpenAI-compatible API base URL.
AI_BASE_URL=https://openrouter.ai/api/v1

# How long hearing and vision records remain in short-term memory.
MEMORY_RETENTION_MS=600000
# How much recent memory is included in each LLM request.
BRAIN_CONTEXT_WINDOW_MS=120000

# Live context
# Comma-separated streamer aliases used to interpret speech and generate danmaku.
LIVE_STREAMER_ALIASES=

# Local ASR / VAD
# Audio sample rate expected by ASR and VAD.
SAMPLE_RATE=16000
# Maximum pending audio duration in seconds.
MAX_PENDING_SECONDS=30
# sherpa-onnx execution provider.
PROVIDER=cpu
# Speech recognizer worker threads.
NUM_THREADS=2
# Voice activity detector worker threads.
VAD_NUM_THREADS=1
# Enable sherpa-onnx diagnostic logging with 1.
DEBUG=0

# SenseVoice ONNX model path. Empty uses the bundled model.
SENSEVOICE_MODEL=
# SenseVoice token file path. Empty uses the bundled tokens.
TOKENS=
# Number of acoustic feature dimensions.
FEATURE_DIM=80
# Enable inverse text normalization with 1.
USE_ITN=1

# VAD implementation: "silero" or "ten".
VAD_KIND=silero
# VAD model path. Empty uses the bundled model matching VAD_KIND.
VAD_MODEL=
# Minimum speech confidence from 0 to 1.
VAD_THRESHOLD=0.5
# Minimum speech duration in seconds.
VAD_MIN_SPEECH=0.25
# Minimum silence duration in seconds before closing a segment.
VAD_MIN_SILENCE=0.5
# Number of samples processed per VAD window (Silero: 512, TEN-VAD: 256).
VAD_WINDOW_SIZE=512

# Bilibili login synchronization
# WebSocket endpoint used to receive synchronized login credentials.
LOGIN_SYNC_URL=
# Shared password used to authenticate with the login synchronization service.
LOGIN_SYNC_PASSWORD=
