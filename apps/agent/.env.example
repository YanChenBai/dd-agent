# Runtime
# Stop automatically after N milliseconds. Set 0 to keep running until Ctrl+C.
AGENT_STOP_AFTER_MS=0

# OpenAI / OpenAI-compatible transcript recovery
# Leave OPENAI_API_KEY and OPENAI_BASE_URL empty to disable AI recovery and print only local ASR final text.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_TRANSCRIPT_MODEL=gpt-4.1-mini

# Use "responses" for OpenAI Responses API compatible providers.
# Use "chat" for providers that only expose /v1/chat/completions.
OPENAI_TRANSCRIPT_API=responses

# Optional for official OpenAI projects.
OPENAI_ORG_ID=
OPENAI_PROJECT_ID=

# Example: third-party OpenAI-compatible provider
# OPENAI_BASE_URL=https://api.example.com/v1
# OPENAI_API_KEY=sk-example
# OPENAI_TRANSCRIPT_MODEL=provider-model-name
# OPENAI_TRANSCRIPT_API=chat

# Live context for transcript recovery
LIVE_PLATFORM=
LIVE_STREAMER_NAME=
LIVE_STREAMER_NICKNAMES=
LIVE_ROOM_TITLE=
LIVE_TOPIC=
LIVE_CONTEXT=

# Local ASR / VAD
SHERPA_ONNX_SAMPLE_RATE=16000
SHERPA_ONNX_MAX_PENDING_SECONDS=30
SHERPA_ONNX_PROVIDER=cpu
SHERPA_ONNX_NUM_THREADS=2
SHERPA_ONNX_VAD_NUM_THREADS=1
SHERPA_ONNX_DEBUG=0

# SenseVoice ASR defaults are resolved from apps/agent/models.
# Override only when using custom model paths.
SHERPA_ONNX_SENSEVOICE_MODEL=
SHERPA_ONNX_TOKENS=
SHERPA_ONNX_FEATURE_DIM=80
SHERPA_ONNX_USE_ITN=1

# VAD defaults to ten-vad. Use "silero" to switch back to Silero VAD.
SHERPA_ONNX_VAD_KIND=ten
SHERPA_ONNX_VAD_MODEL=
SHERPA_ONNX_VAD_THRESHOLD=0.5
SHERPA_ONNX_VAD_MIN_SPEECH=0.25
SHERPA_ONNX_VAD_MIN_SILENCE=0.5
SHERPA_ONNX_VAD_WINDOW_SIZE=256
